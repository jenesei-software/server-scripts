# ===============================
# Remnawave Node setup
# ===============================
REMNAWAVE_NODE_INSTALL_DIR=/opt/remnanode
REMNAWAVE_NODE_CERT_DIR=/etc/ssl/remnawave-node

# Optional. When empty, setup skips TLS certificate issuance and does not pass
# SSL_CERT or SSL_KEY to the container.
SERVER_DOMAIN=node.example.com

# Required only when SERVER_DOMAIN is set.
DOMAIN_MAIL=admin@example.com

PORT_NODE=22222
NODE_SECRET=change_me_super_secret_key
REMNAWAVE_NODE_IMAGE=remnawave/node:latest

# true disables IPv6. false actively enables IPv6 and allows UFW to create IPv6 rules.
DISABLE_IPV6=true
IPV6_INTERFACE=

# Comma-separated inbound ports to allow through UFW.
# Example: 30000,30001
PORT_ARRAY_INBOUNDS=30000,30001

# Optional. The script is started by root, but Docker Compose operations run as
# this user when REMNAWAVE_NODE_SYSTEM_USER is set. The user is added to the docker group.
REMNAWAVE_NODE_SYSTEM_USER=
REMNAWAVE_NODE_SYSTEM_PASSWORD=
REMNAWAVE_NODE_SYSTEM_SSH_PUB=""
