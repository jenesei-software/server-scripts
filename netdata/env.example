# =========================
# Netdata setup through Caddy
# =========================
NETDATA_URL=https://server.cyrilstrone.com
NETDATA_INSTALL_DIR=/opt/netdata
NETDATA_BIND_IP=127.0.0.1
NETDATA_PORT=19999

NETDATA_IMAGE=netdata/netdata:stable
NETDATA_CONTAINER_NAME=netdata
NETDATA_HOSTNAME=server-monitor
NETDATA_DISABLE_TELEMETRY=true

# true: update /etc/caddy/Caddyfile with a managed Netdata reverse_proxy block.
# false: install Netdata only and configure Caddy yourself.
NETDATA_CONFIGURE_CADDY=true
CADDYFILE=/etc/caddy/Caddyfile

# Netdata has no app login in this setup, so Caddy basic auth is enabled by default.
NETDATA_BASIC_AUTH_ENABLED=true
NETDATA_BASIC_AUTH_USER=admin
NETDATA_BASIC_AUTH_PASSWORD=change_me_netdata_password

# What to do if NETDATA_URL is already present in Caddyfile and points somewhere else:
# ask   - ask before replacing the existing Caddy block
# true  - replace it without asking
# false - stop with an error
NETDATA_CADDY_OVERWRITE_DOMAIN=ask
