# ===============================
# Remnawave Panel setup
# ===============================
PANEL_DOMAIN=panel.example.com
REMNAWAVE_PANEL_INSTALL_DIR=/opt/remnawave
REMNAWAVE_PANEL_BIND_IP=127.0.0.1
REMNAWAVE_PANEL_PORT=3000
REMNAWAVE_METRICS_PORT=3001

# Optional fallback. When empty and SUBSCRIPTION_PAGE_DOMAIN is set,
# setup-subscription-page.sh uses the subscription domain automatically.
# When both are empty, setup-remnawave-panel.sh falls back to PANEL_DOMAIN/api/sub.
SUB_PUBLIC_DOMAIN=

APP_PORT=3000
METRICS_PORT=3001
API_INSTANCES=1
IS_DOCS_ENABLED=false
SWAGGER_PATH=/docs
SCALAR_PATH=/scalar
METRICS_USER=admin

# Optional Postgres settings. Password is generated automatically on first run.
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# true: update /etc/caddy/Caddyfile with a managed Remnawave Panel reverse_proxy block.
# false: install Remnawave Panel only and configure Caddy yourself.
REMNAWAVE_PANEL_CONFIGURE_CADDY=true
CADDYFILE=/etc/caddy/Caddyfile

# What to do if PANEL_DOMAIN is already present in Caddyfile and points somewhere else:
# ask   - ask before replacing the existing Caddy block
# true  - replace it without asking
# false - stop with an error
REMNAWAVE_PANEL_CADDY_OVERWRITE_DOMAIN=ask

# Optional. The script is started by root, but Docker Compose operations run as
# this user when REMNAWAVE_PANEL_SYSTEM_USER is set. The user is added to the docker group.
REMNAWAVE_PANEL_SYSTEM_USER=
REMNAWAVE_PANEL_SYSTEM_PASSWORD=
REMNAWAVE_PANEL_SYSTEM_SSH_PUB=""

# ===============================
# Bundled subscription page
# ===============================
SUBSCRIPTION_PAGE_DOMAIN=sub.panel.example.com
SUBSCRIPTION_PAGE_BIND_IP=127.0.0.1
SUBSCRIPTION_PAGE_PORT=3010
REMNAWAVE_API_TOKEN=

CUSTOM_SUB_PREFIX=
MARZBAN_LEGACY_LINK_ENABLED=false
MARZBAN_LEGACY_SECRET_KEY=
CADDY_AUTH_API_TOKEN=
