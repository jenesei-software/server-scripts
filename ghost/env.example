# =========================
# Ghost setup through Caddy
# =========================

# The script is started by root, but Ghost CLI is executed as this Ghost service user.
# Do not use "root" or "ghost" here.
GHOST_SYSTEM_USER=ghostadmin
GHOST_SYSTEM_PASSWORD=change_me_system_user_password
GHOST_SYSTEM_SSH_PUB=""

GHOST_URL=https://example.com
GHOST_INSTALL_DIR=/var/www/ghost
GHOST_PORT=2368
GHOST_BIND_IP=127.0.0.1

# false disables Ghost staff email verification codes for new devices.
# Keep false if transactional email is not configured.
GHOST_STAFF_DEVICE_VERIFICATION=false

# Database created automatically by this module.
GHOST_DB_NAME=ghost_prod
GHOST_DB_USER=ghost
GHOST_DB_PASSWORD=change_me_ghost_db_password

# Node.js major version from the Ghost Ubuntu install guide.
GHOST_NODE_MAJOR=22

# true: update /etc/caddy/Caddyfile with a managed Ghost reverse_proxy block.
# false: install Ghost only and configure Caddy yourself.
GHOST_CONFIGURE_CADDY=true
CADDYFILE=/etc/caddy/Caddyfile

# What to do if GHOST_URL is already present in Caddyfile and points somewhere else:
# ask   - ask before replacing the existing Caddy block
# true  - replace it without asking
# false - stop with an error
GHOST_CADDY_OVERWRITE_DOMAIN=ask

# Optional. Leave empty for the default MySQL root socket login.
# Use these only if the server already has MySQL root password auth configured.
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=
