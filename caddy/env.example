# =========================
# Caddy setup
# =========================
# Default mode: install/start Caddy only.
# Leave CADDY_DOMAIN and CADDY_UPSTREAM empty when domains will be added by service modules.
CADDY_DOMAIN=
CADDY_UPSTREAM=
CADDY_EMAIL=
CADDYFILE=/etc/caddy/Caddyfile

# Optional reverse proxy example:
# CADDY_DOMAIN=example.com
# CADDY_UPSTREAM=http://127.0.0.1:8080
# CADDY_EMAIL=admin@example.com
