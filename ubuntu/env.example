# =========================
# Ubuntu base setup
# =========================
ROOT_PASSWORD=change_me_root_password
USER_NAME=deploy
USER_PASSWORD=change_me_user_password
PORT_SSH=10022
SSH_PUB="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... your@email"
SERVER_IP_V4=203.0.113.10
SERVER_NAME=ubuntu-prod-01

# Leave empty to keep the current IPv6 state.
# true disables IPv6. false actively enables IPv6 and allows UFW to create IPv6 rules.
DISABLE_IPV6=

# Optional when DISABLE_IPV6=false. Leave empty to auto-detect, or set eth0/ens3/etc.
IPV6_INTERFACE=
