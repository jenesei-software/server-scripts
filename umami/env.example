# =========================
# Umami setup through Caddy
# =========================
UMAMI_URL=https://analytics.example.com
UMAMI_INSTALL_DIR=/opt/umami
UMAMI_BIND_IP=127.0.0.1
UMAMI_PORT=3000

UMAMI_IMAGE=docker.umami.is/umami-software/umami:postgresql-latest
UMAMI_CONTAINER_NAME=umami
UMAMI_DB_CONTAINER_NAME=umami-db
POSTGRES_IMAGE=postgres:15-alpine

UMAMI_DB_NAME=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=change_me_umami_db_password
UMAMI_APP_SECRET=change_me_random_app_secret
UMAMI_DISABLE_TELEMETRY=1

# Optional. The script is started by root, but Docker Compose operations run as
# this user when UMAMI_SYSTEM_USER is set. The user is added to the docker group.
UMAMI_SYSTEM_USER=
UMAMI_SYSTEM_PASSWORD=
UMAMI_SYSTEM_SSH_PUB=""

# true: update /etc/caddy/Caddyfile with a managed Umami reverse_proxy block.
# false: install Umami only and configure Caddy yourself.
UMAMI_CONFIGURE_CADDY=true
CADDYFILE=/etc/caddy/Caddyfile

# What to do if UMAMI_URL is already present in Caddyfile and points somewhere else:
# ask   - ask before replacing the existing Caddy block
# true  - replace it without asking
# false - stop with an error
UMAMI_CADDY_OVERWRITE_DOMAIN=ask
