# ============================
# Supabase setup through Caddy
# ============================
SUPABASE_URL=https://supabase.example.com
SUPABASE_SITE_URL=https://app.example.com
SUPABASE_ADDITIONAL_REDIRECT_URLS=

SUPABASE_INSTALL_DIR=/opt/supabase
SUPABASE_REPOSITORY=https://github.com/supabase/supabase.git
SUPABASE_BRANCH=master

# Kong API gateway is exposed only locally. Caddy proxies public HTTPS to it.
SUPABASE_BIND_IP=127.0.0.1
SUPABASE_KONG_HTTP_PORT=8000
SUPABASE_KONG_HTTPS_PORT=8443

# Supavisor Postgres ports are exposed only locally by default.
SUPABASE_DB_BIND_IP=127.0.0.1
SUPABASE_POSTGRES_PORT=5432
SUPABASE_POOLER_TRANSACTION_PORT=6543
SUPABASE_POOLER_TENANT_ID=default

SUPABASE_DASHBOARD_USERNAME=supabase
SUPABASE_DASHBOARD_PASSWORD=change_me_supabase_dashboard_password
SUPABASE_POSTGRES_PASSWORD=change_me_supabase_postgres_password

SUPABASE_STUDIO_DEFAULT_ORGANIZATION=DefaultOrganization
SUPABASE_STUDIO_DEFAULT_PROJECT=DefaultProject
SUPABASE_OPENAI_API_KEY=

SUPABASE_DISABLE_SIGNUP=false
SUPABASE_ENABLE_EMAIL_SIGNUP=true
SUPABASE_ENABLE_EMAIL_AUTOCONFIRM=false
SUPABASE_ENABLE_PHONE_SIGNUP=false
SUPABASE_ENABLE_PHONE_AUTOCONFIRM=false

# Configure real SMTP before using email confirmations, invites, and recovery.
SUPABASE_SMTP_ADMIN_EMAIL=admin@example.com
SUPABASE_SMTP_HOST=supabase-mail
SUPABASE_SMTP_PORT=2500
SUPABASE_SMTP_USER=fake_mail_user
SUPABASE_SMTP_PASS=fake_mail_password
SUPABASE_SMTP_SENDER_NAME=fake_sender

# Optional. The script is started by root, but Supabase Docker Compose operations
# run as this user when SUPABASE_SYSTEM_USER is set. The user is added to the docker group.
SUPABASE_SYSTEM_USER=
SUPABASE_SYSTEM_PASSWORD=
SUPABASE_SYSTEM_SSH_PUB=""

# true: enable Supabase logs and analytics containers.
# false: keep the lighter default stack.
SUPABASE_ENABLE_LOGS=false

# true: update /etc/caddy/Caddyfile with a managed Supabase reverse_proxy block.
# false: install Supabase only and configure Caddy yourself.
SUPABASE_CONFIGURE_CADDY=true
CADDYFILE=/etc/caddy/Caddyfile

# What to do if SUPABASE_URL is already present in Caddyfile and points somewhere else:
# ask   - ask before replacing the existing Caddy block
# true  - replace it without asking
# false - stop with an error
SUPABASE_CADDY_OVERWRITE_DOMAIN=ask

# true: rotate Supabase generated JWT/API/storage secrets on the next setup run.
# Keep false after first setup unless you intentionally want to rotate credentials.
SUPABASE_FORCE_REGENERATE_SECRETS=false
