# =========================
# Uptime Kuma setup through Caddy
# =========================
UPTIME_KUMA_URL=https://status.cyrilstrone.com
UPTIME_KUMA_INSTALL_DIR=/opt/uptime-kuma
UPTIME_KUMA_BIND_IP=127.0.0.1
UPTIME_KUMA_PORT=3001

UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2
UPTIME_KUMA_CONTAINER_NAME=uptime-kuma
UPTIME_KUMA_TIMEZONE=UTC

# true: update /etc/caddy/Caddyfile with a managed Uptime Kuma reverse_proxy block.
# false: install Uptime Kuma only and configure Caddy yourself.
UPTIME_KUMA_CONFIGURE_CADDY=true
CADDYFILE=/etc/caddy/Caddyfile

# Optional Caddy basic auth in front of Uptime Kuma.
# Uptime Kuma has its own login after first setup, so this is disabled by default.
UPTIME_KUMA_BASIC_AUTH_ENABLED=false
UPTIME_KUMA_BASIC_AUTH_USER=admin
UPTIME_KUMA_BASIC_AUTH_PASSWORD=

# What to do if UPTIME_KUMA_URL is already present in Caddyfile and points somewhere else:
# ask   - ask before replacing the existing Caddy block
# true  - replace it without asking
# false - stop with an error
UPTIME_KUMA_CADDY_OVERWRITE_DOMAIN=ask
